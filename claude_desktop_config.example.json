{
  "mcpServers": {
    "telegraph-docs": {
      "command": "bun",
      "args": ["/ABSOLUTE/PATH/TO/mcp-repo-docs/build/index.js"],
      "env": {
        "MCP_REPO_ROOT": "/ABSOLUTE/PATH/TO/telegraph",
        "MCP_TOOL_PREFIX": "telegraph",
        "MCP_URI_SCHEME": "telegraph",
        "MCP_REPO_LABEL": "defstudio/telegraph"
      }
    },
    "laravel-data-docs": {
      "command": "bun",
      "args": ["/ABSOLUTE/PATH/TO/mcp-repo-docs/build/index.js"],
      "env": {
        "MCP_REPO_ROOT": "/ABSOLUTE/PATH/TO/laravel-data",
        "MCP_TOOL_PREFIX": "laravel_data",
        "MCP_URI_SCHEME": "laravel-data",
        "MCP_REPO_LABEL": "spatie/laravel-data"
      }
    }
  }
}
