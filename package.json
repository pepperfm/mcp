{
  "name": "repo-docs-mcp-bun",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Generic MCP stdio server that exposes a local repository's docs + code (Bun-friendly)",
  "keywords": ["mcp", "bun", "stdio", "docs", "repository"],
  "license": "MIT",
  "scripts": {
    "dev": "bun run src/index.ts",
